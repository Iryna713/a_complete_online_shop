<article class="product-item">
  <img src="<%= item.imageUrl %>" alt="<%= item.title %>">
  <div class="product-item-content">
    <h2>
      <%= item.title %>
    </h2>
    <div class="product-item-actions">
      <a href="/admin/products/<%= item.id %>" class="btn btn-alt">View & Edit</a>
      <button class="btn btn-alt" data-productid="<%= item.id %>" data-csrf="<%= locals.csrfToken %>">Delete</button>
    </div>
  </div>
</article>